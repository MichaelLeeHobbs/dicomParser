{
    "name": "@ubercode/dicom-parser",
    "version": "2.0.0-alpha.0",
    "description": "TypeScript remake of dicomParser: parse and write DICOM Part-10, zero runtime dependencies. Fork of cornerstonejs/dicomParser.",
    "type": "module",
    "packageManager": "pnpm@10.33.4",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./compat": {
            "types": "./dist/compat.d.ts",
            "import": "./dist/compat.js",
            "require": "./dist/compat.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsdown",
        "clean": "rimraf dist coverage",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint --max-warnings 0 .",
        "lint:fix": "eslint --fix --max-warnings 0 .",
        "format": "prettier --write \"{src,tests}/**/*.{ts,md,json}\" \"*.{ts,mjs,json,md}\" \".github/**/*.yml\"",
        "format:check": "prettier --check \"{src,tests}/**/*.{ts,md,json}\" \"*.{ts,mjs,json,md}\" \".github/**/*.yml\"",
        "typecheck": "node node_modules/ts7/bin/tsc --noEmit",
        "typecheck:ts6": "tsc --noEmit",
        "dry-run": "npm pack --dry-run",
        "prepublishOnly": "pnpm run clean && pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run build",
        "docs": "typedoc",
        "bench": "vitest run tests/benchmark.test.ts"
    },
    "keywords": [
        "dicom",
        "dicom-parser",
        "dicom-writer",
        "part-10",
        "medical-imaging",
        "typescript",
        "healthcare"
    ],
    "author": "Michael Hobbs",
    "contributors": [
        "Chris Hafey <chafey@gmail.com> (original dicomParser)"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MichaelLeeHobbs/dicomParser.git"
    },
    "bugs": {
        "url": "https://github.com/MichaelLeeHobbs/dicomParser/issues"
    },
    "homepage": "https://github.com/MichaelLeeHobbs/dicomParser#readme",
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "dicom-parser": "1.8.21",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "fast-check": "^4.9.0",
        "prettier": "^3.9.6",
        "rimraf": "^6.1.3",
        "ts7": "npm:typescript@7.0.2",
        "tsdown": "^0.22.13",
        "typedoc": "^0.28.20",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.65.0",
        "unrun": "^0.3.1",
        "vitest": "^4.1.10"
    }
}
